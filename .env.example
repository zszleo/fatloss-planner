# Fatloss Planner Configuration
# Copy this file to .env and adjust values as needed

# Database Configuration
DATABASE_URL=sqlite:///./data/fatloss.db
# Alternative: PostgreSQL
# DATABASE_URL=postgresql://user:password@localhost:5432/fatloss

# Application Settings
APP_DEBUG=false
APP_LOG_LEVEL=INFO

# Calculation Constants (can be overridden)
CARBS_CALORIES_PER_GRAM=4
PROTEIN_CALORIES_PER_GRAM=4
FAT_CALORIES_PER_GRAM=9
EXERCISE_CALORIES_PER_MINUTE=10
MAX_MONTHLY_WEIGHT_LOSS_PERCENT=0.05
CARB_ADJUSTMENT_UNIT_GRAMS=30

# UI Settings (if applicable)
THEME=light
LANGUAGE=zh_CN

# API Settings (if using Web version)
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=4
